# 1. ตั้งค่าเบื้องต้นของ Script
# ==========================================
# ควบคุมว่า script จะทำงานหรือไม่ (รับค่าจาก Dynamo input)
is_active = IN[0] if isinstance(IN[0], bool) else True

# List ของ Category ที่จะข้ามการเปลี่ยนสี (เพราะเป็นสิ่งพิเศษ)
default_exclusions = ["Revision Clouds", "Revision Cloud Tags"]

# สีดำ RGB(0,0,0) ที่จะใช้แทนที่สีดั้งเดิมชั่วคราว (บรรทัด 195-196 ใช้สีนี้)
black_color = RevitColor(0, 0, 0)

# ชื่อ Printer เริ่มต้น (ถ้าพบในระบบจะเลือกอัตโนมัติ)
target_printer_name = "PDF24" 

# ==========================================
# 2. เตรียมข้อมูล Categories, Printers, Settings
# ==========================================

# ฟังก์ชัน: เรียงลำดับ String ที่มี Numbers ให้ถูกต้อง (เช่น 2 มาก่อน 10)
# ใช้ที่: บรรทัด 73, 80, 87 เพื่อเรียงลำดับ categories, printers, settings
def natural_sort_key(text):
    return [int(c) if c.isdigit() else c.lower() for c in re.split('([0-9]+)', text)]

# ฟังก์ชัน: แปลงค่า Hex Color เป็น WPF Brush สำหรับ UI
# ใช้ที่: บรรทัด 127, 153, 239 เพื่อสร้างสี Background ของปุ่ม
def get_brush(hex_code):
    return SolidColorBrush(ColorConverter.ConvertFromString(hex_code))

# สร้าง Map ของ Category ทั้งหมดใน Document
# Key = ชื่อ Category หรือ "Parent > Subcategory"
# Value = Reference ไปยัง Category Object ที่จะเปลี่ยนสี (บรรทัด 195-196, 260)
item_data_map = {}
for cat in doc.Settings.Categories:
    try:
        # ข้ามไฟล์ DWG Import
        if ".dwg" in cat.Name.lower(): 
            continue
        item_data_map[cat.Name] = cat
        
        # เพิ่ม Subcategory ทั้งหมด (เช่น "Line Styles > Hidden Line")
        if cat.SubCategories.Size > 0:
            for subcat in cat.SubCategories:
                if ".dwg" not in subcat.Name.lower():
                    item_data_map["{}  >  {}".format(cat.Name, subcat.Name)] = subcat
    except: 
        pass

# ดึง List ของ Printer ทั้งหมดจากระบบ
# ใช้ที่: UI ComboBox (บรรทัด 148)
printers_list = [p for p in PrinterSettings.InstalledPrinters]
printers_list.sort(key=natural_sort_key)

# ดึง Print Settings ทั้งหมดจาก Document
# ใช้ที่: UI ComboBox (บรรทัด 151) และ บรรทัด 231
print_settings_list = []
ps_elems = FilteredElementCollector(doc).OfClass(PrintSetting).ToElements()
for ps in ps_elems:
    if ps.Name: 
        print_settings_list.append(ps.Name)
print_settings_list.sort(key=natural_sort_key)

# ดึง View/Sheet Set ทั้งหมดจาก Document
# ใช้ที่: UI ComboBox (บรรทัด 154) และ บรรทัด 235
view_sets_list = []
vs_elems = FilteredElementCollector(doc).OfClass(ViewSheetSet).ToElements()
for vs in vs_elems:
    if vs.Name and not vs.Name.startswith("<"):
        view_sets_list.append(vs.Name)
view_sets_list.sort(key=natural_sort_key)

