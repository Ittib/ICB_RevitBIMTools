# ==========================================
# 1. Config & Initial Setup (บรรทัด 35-39)
# ==========================================
# บรรทัด 36: ตรวจสอบว่า input IN[0] เป็น boolean หรือไม่ เพื่อเปิด/ปิด script
is_active = IN[0] if isinstance(IN[0], bool) else True
# บรรทัด 37: รายการ categories ที่ต้องการแยกออก (ใช้ที่ Line 319 เพื่อเช็ค checkbox default)
default_exclusions = ["Revision Clouds", "Revision Cloud Tags"]
# บรรทัด 38: สร้างตัวแปร RevitColor สีดำ (R=0, G=0, B=0) ใช้ที่ Line 381 เพื่อเปลี่ยนสี
black_color = RevitColor(0, 0, 0)
# บรรทัด 39: ชื่อ Printer ที่ต้องการใช้ default (ใช้ที่ Line 290 เพื่อเลือก printer โดยอัตโนมัติ)
target_printer_name = "PDF24"

# บรรทัด 42-43: ฟังก์ชัน natural_sort_key สำหรับลินห์หมาย (1, 2, 10 แเละชี 1, 2, 3...10 ไม่ใช่ string sort)
# บรรทัด 43: re.split('[0-9]+', text) ภาคก text เป็น list สรคฬ และ ตัวเลข คนดทินไข
# ตัวอย่าง: "Part_1_Elev_10" เป็น ['Part_', 1, '_Elev_', 10, '']
def natural_sort_key(text):
    # บรรทัด 43: List comprehension เเปลงฬไช่ number เป็น int หรือเป็นน้อย lowercase (Line 50)
    return [int(c) if c.isdigit() else c.lower() for c in re.split('([0-9]+)', text)]

# ==========================================
# 2. Data Preparation (List Comprehension) (บรรทัด 47-65)
# ==========================================
# บรรทัด 49: List comprehension ตัวย่อ Printer ที่ลงทะเบยน แร่ปโหลลฬ (Line 291 ใช้ว่หิด)
printers_list = sorted([p for p in PrinterSettings.InstalledPrinters], key=natural_sort_key)

# บรรทัด 50: FilteredElementCollector คนหา PrintSetting objects จาก Revit document
ps_elems = FilteredElementCollector(doc).OfClass(PrintSetting).ToElements()
# บรรทัด 51: List comprehension คนหาชื่อชั่นเท่านัน (Name) ของ PrintSetting ทั้งหมด (Line 293, 407 ใช้ว่หิด)
print_settings_list = sorted([ps.Name for ps in ps_elems if ps.Name], key=natural_sort_key)

# บรรทัด 53: FilteredElementCollector คนหา ViewSheetSet objects จาก Revit document
vs_elems = FilteredElementCollector(doc).OfClass(ViewSheetSet).ToElements()
# บรรทัด 54: List comprehension คนหาชื่อ Name ของ ViewSheetSet ที่ไม่เริ่มต้น < (คำสั่ง "<" คำ) (Line 294, 409 ใช้ว่หิด)
view_sets_list = sorted([vs.Name for vs in vs_elems if vs.Name and not vs.Name.startswith("<")], key=natural_sort_key)

# บรรทัด 56: สร้าง dictionary เปล่าจจุ Category object โดยชื่อ
item_data_map = {}
# บรรทัด 57: Loop งีผ่ขคนหา Category ทั้งหมด จาก Revit document (Line 320 ใช้เช็ค)
for cat in doc.Settings.Categories:
    # บรรทัด 58: Try-except ขำด ต่อในการ loop กื่อจับควร exception ถ้า category ไม่มี property ใน การ access
    try:
        # บรรทัด 59: ข้าม skip คำต็อหลายใหญ่ที่มี ".dwg" ใน name
        if ".dwg" in cat.Name.lower(): continue
        # บรรทัด 60: เช็ค category name ตจิ่งสค key และ category object เป็ม value (Line 320 ใช้เช็ค)
        item_data_map[cat.Name] = cat
        # บรรทัด 61: Loop ใง Subcategories ของ category
        for subcat in cat.SubCategories:
            # บรรทัด 62: Skip subcategories ที่มี ".dwg" ใน name
            if ".dwg" not in subcat.Name.lower():
                # บรรทัด 63: เช็ค subcategory แบบ "Parent  >  Child" (Line 320 ใช้ต่อง format)
                item_data_map["{}  >  {}".format(cat.Name, subcat.Name)] = subcat
    # บรรทัด 64: Exception handler สำหรับ exception กุนเศษ AttributeError (ฉันดัร .SubCategories property ไม่มี)
    except AttributeError:
        # บรรทัด 65: Pass เชินตั่ว loop ต่อ ไป
        pass  # ดักจับเฉพาะไม่มี Property ไม่เหมารวม

# ==========================================
# 3. UI XAML Definition & Class
# ==========================================
# ย้ายการสร้าง UI ทั้งหมดมาเป็น XAML String โค้ดจะสะอาดและแก้ไขง่ายขึ้นมาก
XAML_UI = """
<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        Title="Itti Drawing Plot Manager" Width="500" Height="800" Background="#F5F5F5" Topmost="True" WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <Label Content="1. เลือกรายการที่ต้องการ Exclude:" FontWeight="Bold"/>
        <TextBox Name="txtSearch" Height="25" Margin="0,5,0,5"/>
        <ListBox Name="lbCategories" Height="200"/>
        
        <Label Content="2. ตั้งค่าการ Plot:" FontWeight="Bold" Margin="0,15,0,0"/>
        <TextBlock Text="เลือก Printer:" Margin="5,5,0,0"/>
        <ComboBox Name="cbPrinter" Margin="0,2,0,10"/>
        <TextBlock Text="เลือก Print Setting:" Margin="5,5,0,0"/>
        <ComboBox Name="cbPrintSetting" Margin="0,2,0,10"/>
        <TextBlock Text="เลือก View / Sheet Set:" Margin="5,5,0,0"/>
        <ComboBox Name="cbViewSet" Margin="0,2,0,10"/>
        
        <TextBlock Text="รูปแบบการเซฟไฟล์:" FontWeight="Bold" Margin="5,0,0,5"/>
        <RadioButton Name="rbCombine" Content="Combine views/sheets into a single file" IsChecked="True" Margin="5,0,0,5"/>
        <RadioButton Name="rbSeparate" Content="Create separate files" Margin="5,0,0,10"/>
        
        <TextBlock Text="โฟลเดอร์สำหรับเซฟไฟล์ (Output Path):" Margin="5,0,0,2"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
            <TextBox Name="txtPath" Width="350" Height="25" Margin="5,0,5,0" Text="C:\\Temp"/>
            <Button Name="btnBrowse" Content="Browse..." Width="80" Height="25"/>
        </StackPanel>
        
        <CheckBox Name="chkDoPrint" Content="สั่ง Plot ทันที (พร้อมระบบเช็คคิวอัจฉริยะ)" IsChecked="True" Margin="0,0,0,10"/>
        <Button Name="btnRun" Content="RUN PROCESS" Height="50" Background="#212121" Foreground="#FFFFFF" FontWeight="Bold"/>
    </StackPanel>
</Window>
"""

class FullProcessSelector(object):
    def __init__(self, item_map, p_list, v_list, printer_list):
        self.item_map = item_map
        self.sorted_names = sorted(self.item_map.keys(), key=natural_sort_key)
        self.checkbox_map = {}
        self.excluded_list = []
        
        # Load XAML
        self.window = XamlReader.Load(XmlReader.Create(StringReader(XAML_UI)))
        
        # Bind Controls
        self.txtSearch = self.window.FindName("txtSearch")
        self.lbCategories = self.window.FindName("lbCategories")
        self.cbPrinter = self.window.FindName("cbPrinter")
        self.cbPrintSetting = self.window.FindName("cbPrintSetting")
        self.cbViewSet = self.window.FindName("cbViewSet")
        self.rbCombine = self.window.FindName("rbCombine")
        self.txtPath = self.window.FindName("txtPath")
        self.btnBrowse = self.window.FindName("btnBrowse")
        self.chkDoPrint = self.window.FindName("chkDoPrint")
        self.btnRun = self.window.FindName("btnRun")
        
        # Set Data to Controls
        self.cbPrinter.ItemsSource = printer_list
        if target_printer_name in printer_list: self.cbPrinter.SelectedItem = target_printer_name
        elif printer_list: self.cbPrinter.SelectedIndex = 0
        
        self.cbPrintSetting.ItemsSource = p_list
        if p_list: self.cbPrintSetting.SelectedIndex = 0
        
        self.cbViewSet.ItemsSource = v_list
        if v_list: self.cbViewSet.SelectedIndex = 0
        
        self.refresh_list("")
        
        # Events
        self.txtSearch.TextChanged += self.on_search_changed
        self.btnBrowse.Click += self.on_browse
        self.btnRun.Click += self.on_submit
        
    def ShowDialog(self): return self.window.ShowDialog()
        
    def on_browse(self, sender, e):
        dialog = FolderBrowserDialog()
        dialog.Description = u"เลือกโฟลเดอร์สำหรับบันทึกไฟล์ PDF"
        if dialog.ShowDialog() == DialogResult.OK: self.txtPath.Text = dialog.SelectedPath

    def refresh_list(self, txt):
        self.lbCategories.Items.Clear()
        search = txt.lower()
        for name in self.sorted_names:
            if search in name.lower():
                if name not in self.checkbox_map:
                    cb = CheckBox()
                    cb.Content = name
                    # List comprehension แบบ one-liner สำหรับเช็ค default exclusions
                    if any(d_ex == name or d_ex in name.split("  >  ") for d_ex in default_exclusions):
                        cb.IsChecked = True
                    self.checkbox_map[name] = cb
                self.lbCategories.Items.Add(self.checkbox_map[name])

    def on_search_changed(self, sender, e): self.refresh_list(self.txtSearch.Text)

    def on_submit(self, sender, e):
        # List Comprehension สำหรับแปลง Checkbox ที่เลือก เป็น List ของ Category objects
        self.excluded_list = [self.item_map[name] for name, cb in self.checkbox_map.items() if cb.IsChecked]
        self.window.DialogResult = True
        self.window.Close()

# ==========================================
# 4. Main Process Logic
# ==========================================
OUT_MSG = u"UI ถูกยกเลิก"

if is_active:
    try:
        form = FullProcessSelector(item_data_map, print_settings_list, view_sets_list, printers_list)
        if form.ShowDialog():
            
            # --- Change Color ---
            original_colors = {}
            t_black = Transaction(doc, "MTC: Temp Black")
            t_black.Start()
            for name, cat in item_data_map.items():
                if cat not in form.excluded_list:
                    try:
                        curr = cat.LineColor
                        if curr.Red != 0 or curr.Green != 0 or curr.Blue != 0:
                            original_colors[name] = curr
                            cat.LineColor = black_color
                    except AttributeError: pass
            t_black.Commit()
            
            # --- Print Process ---
            if form.chkDoPrint.IsChecked:
                try:
                    pm = doc.PrintManager
                    selected_printer = form.cbPrinter.SelectedItem
                    
                    t_print = Transaction(doc, "MTC: Setup Print")
                    t_print.Start()
                    
                    pm.SelectNewPrintDriver(selected_printer)
                    pm.PrintRange = pm.PrintRange.Select
                    pm.PrintToFile = True 
                    out_dir = form.txtPath.Text
                    if not os.path.exists(out_dir): os.makedirs(out_dir)

                    pm.CombinedFile = form.rbCombine.IsChecked
                    filename = "Combined_Print.pdf" if pm.CombinedFile else "Sheet.pdf"
                    pm.PrintToFileName = os.path.join(out_dir, filename)
                    
                    # ใช้ Python generator next() ดึงค่าโดยไม่ต้องลูป for ช่วยให้โค้ดคลีนขึ้น
                    selected_ps = next((ps for ps in ps_elems if ps.Name == form.cbPrintSetting.SelectedItem), None)
                    if selected_ps: pm.PrintSetup.CurrentPrintSetting = selected_ps
                    
                    selected_vs = next((vs for vs in vs_elems if vs.Name == form.cbViewSet.SelectedItem), None)
                    if selected_vs: pm.ViewSheetSetting.CurrentViewSheetSet = selected_vs
                            
                    t_print.Commit()
                    pm.SubmitPrint()
                    
                    # --- Smart Queue Polling ---
                    try:
                        print_server = LocalPrintServer()
                        print_queue = print_server.GetPrintQueue(selected_printer)
                        time.sleep(1)
                        timeout_limit = 120 # ลดเวลา Timeout เหลือ 2 นาที เพื่อไม่ให้โปรแกรม freeze นานเกินเหตุ
                        start_time = time.time()
                        
                        while True:
                            print_queue.Refresh()
                            if print_queue.NumberOfJobs == 0:
                                OUT_MSG = u"✅ พิมพ์เสร็จสมบูรณ์! ทำการคืนค่าสี..."
                                break
                            if (time.time() - start_time) > timeout_limit:
                                OUT_MSG = u"⚠️ ระบบรอคิวนานเกิน 2 นาที (Timeout) ทำการคืนค่าสี..."
                                break
                            time.sleep(1)
                            
                    except Exception:
                        time.sleep(5) # Fallback หดเหลือ 5 วินาที
                        OUT_MSG = u"✅ ส่งคำสั่ง Plot สำเร็จ (เช็คคิวไม่ได้ ใช้ Fallback 5s)"
                        
                except Exception as pe: OUT_MSG = u"❌ Plot Error: " + str(pe)

            # --- Restore Color ---
            t_restore = Transaction(doc, "MTC: Restore Color")
            t_restore.Start()
            for name, color in original_colors.items():
                try: item_data_map[name].LineColor = color
                except Exception: pass
            t_restore.Commit()
            
    except Exception as e:
        OUT_MSG = u"❌ Error: " + str(e)

OUT = OUT_MSG